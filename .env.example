# ===== Required =====
# Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# ===== Football data: TheSportsDB (https://www.thesportsdb.com) =====
# The free tier key "3" already serves full World Cup 2026 fixtures, scores and
# group tables. For higher rate limits, become a Patreon supporter and put your
# personal key here.
FOOTBALL_API_KEY=3
FOOTBALL_BASE_URL=https://www.thesportsdb.com/api/v1/json
# 4429 = FIFA World Cup on TheSportsDB.
LEAGUE_ID=4429
SEASON=2026

# ===== LLM: any OpenAI-compatible chat endpoint =====
# Default is Groq (free, fast). Get a key at https://console.groq.com/keys
# Other options (just swap base URL + model + key):
#   OpenRouter : LLM_BASE_URL=https://openrouter.ai/api/v1            (many free models)
#   OpenAI     : LLM_BASE_URL=https://api.openai.com/v1
#   Gemini     : LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Leave LLM_API_KEY empty to disable AI analysis/chat (scores & standings still work).
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# ===== Channel (all automatic updates post here) =====
# Target channel for results + analysis, group standings, the daily digest, and
# pre-match reminders.
# Public channel: @yourchannel  |  Private channel: numeric -100XXXXXXXXXX id.
# The bot MUST be added as an admin of the channel with "Post Messages" rights.
# (To get a private channel's id, forward any channel post to @userinfobot.)
CHANNEL_ID=

# ===== Optional (sensible defaults shown) =====
# Where the JSON state files live (subscribers, fixtures, sent events...).
DATA_DIR=./data

# Display timezone for all user-facing times.
TZ=Asia/Baghdad

# Local hour (0-23) to send the daily morning fixtures digest.
DIGEST_HOUR=9

# Seconds between live polls *while a match is in its finish window*.
LIVE_POLL_SECONDS=240

# Your personal chat id to receive startup/error pings (optional).
ADMIN_CHAT_ID=
